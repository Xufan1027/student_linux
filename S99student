#!/bin/sh

APP_DIR=/opt/student_linux
DATA_DIR=/userdata/student
LOG_FILE=$DATA_DIR/student.log
PID_FILE=/var/run/student.pid
BLE_PID_FILE=/var/run/student_ble.pid
BT_AGENT_PID_FILE=/var/run/student_bt_agent.pid
STREAM_PID_FILE=/var/run/student_stream.pid
START_DELAY=${START_DELAY:-5}
RESTART_DELAY=${RESTART_DELAY:-3}

log_boot_info() {
    {
        echo "===== student boot $(date) ====="
        echo "[uname]"
        uname -a
        echo "[os-release]"
        cat /etc/os-release 2>/dev/null || true
        echo "[ip]"
        ip addr 2>/dev/null || true
        echo "[bluetooth]"
        hciconfig hci0 2>/dev/null || true
        echo "[arecord]"
        arecord -l 2>/dev/null || true
        echo "[aplay]"
        aplay -l 2>/dev/null || true
        echo "================================"
    } >> "$LOG_FILE" 2>&1
}

start_ble_uart() {
    if [ -f "$BLE_PID_FILE" ] && kill -0 "$(cat "$BLE_PID_FILE")" 2>/dev/null; then
        echo "BLE UART advertising is already running"
        return
    fi
    if [ -x "$APP_DIR/ble_uart_start.sh" ]; then
        (
            cd "$APP_DIR" || exit 1
            ./ble_uart_start.sh
        ) >> "$LOG_FILE" 2>&1 &
        echo $! > "$BLE_PID_FILE"
    fi
}

start_bluetooth_pairing_agent() {
    if [ -f "$BT_AGENT_PID_FILE" ] && kill -0 "$(cat "$BT_AGENT_PID_FILE")" 2>/dev/null; then
        echo "Bluetooth pairing agent is already running"
        return
    fi
    if [ -x "$APP_DIR/bluetooth_pairing_agent.sh" ]; then
        (
            cd "$APP_DIR" || exit 1
            ./bluetooth_pairing_agent.sh
        ) >> "$LOG_FILE" 2>&1 &
        echo $! > "$BT_AGENT_PID_FILE"
    fi
}

stop_ble_uart() {
    if [ -f "$BLE_PID_FILE" ]; then
        kill "$(cat "$BLE_PID_FILE")" 2>/dev/null || true
        rm -f "$BLE_PID_FILE"
    fi
    pkill -f "/opt/student_linux/ble_uart_dbus.py" 2>/dev/null || true
    pkill bluetoothctl 2>/dev/null || true
}

start_board_stream() {
    if [ -f "$STREAM_PID_FILE" ] && kill -0 "$(cat "$STREAM_PID_FILE")" 2>/dev/null; then
        echo "board_stream is already running"
        return
    fi
    (
        cd "$APP_DIR" || exit 1
        while true; do
            python3 board_stream.py
            sleep 2
        done
    ) >> "$LOG_FILE" 2>&1 &
    echo $! > "$STREAM_PID_FILE"
}

stop_board_stream() {
    if [ -f "$STREAM_PID_FILE" ]; then
        kill "$(cat "$STREAM_PID_FILE")" 2>/dev/null || true
        rm -f "$STREAM_PID_FILE"
    fi
    pkill -f "$APP_DIR/board_stream.py" 2>/dev/null || true
    pkill -f "python3 board_stream.py" 2>/dev/null || true
    pkill -f "/opt/python/bin/python3 board_stream.py" 2>/dev/null || true
    pkill -f "board_stream.py" 2>/dev/null || true
}

stop_bluetooth_pairing_agent() {
    if [ -f "$BT_AGENT_PID_FILE" ]; then
        kill "$(cat "$BT_AGENT_PID_FILE")" 2>/dev/null || true
        rm -f "$BT_AGENT_PID_FILE"
    fi
    pkill -f "/opt/student_linux/bluetooth_pairing_agent.sh" 2>/dev/null || true
    pkill -f "/opt/student_linux/bluetooth_pairing_agent.py" 2>/dev/null || true
    pkill bluetoothctl 2>/dev/null || true
}

case "$1" in
    start)
        echo "Starting student bluetooth client"
        mkdir -p "$DATA_DIR" /var/run
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "student is already running"
            exit 0
        fi
        log_boot_info
        sh "$APP_DIR/audio_init.sh" >> "$LOG_FILE" 2>&1
        start_bluetooth_pairing_agent
        start_ble_uart
        start_board_stream
        (
            sleep "$START_DELAY"
            cd "$APP_DIR" || exit 1
            while true; do
                echo "[$(date)] student main starting"
                ./start.sh
                rc=$?
                echo "[$(date)] student main exited rc=$rc, restart after ${RESTART_DELAY}s"
                sleep "$RESTART_DELAY"
            done
        ) >> "$LOG_FILE" 2>&1 &
        echo $! > /var/run/student.pid
        ;;
    stop)
        echo "Stopping student bluetooth client"
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")" 2>/dev/null || true
            rm -f "$PID_FILE"
        fi
        stop_bluetooth_pairing_agent
        stop_ble_uart
        stop_board_stream
        pkill -f "python3 main.py" 2>/dev/null || true
        pkill -f "/opt/python/bin/python3 main.py" 2>/dev/null || true
        pkill -f "$APP_DIR/main.py" 2>/dev/null || true
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "student is running"
            exit 0
        fi
        echo "student is stopped"
        exit 1
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
